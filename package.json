    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.9"
  },
  "overrides": {
    "dotenv": "$dotenv",
    "zod": "$zod"
