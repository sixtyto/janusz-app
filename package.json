    "@bull-board/h3": "^7.0.0",
    "@bull-board/ui": "^7.0.0",
    "@google/genai": "^1.52.0",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.46",
    "@langchain/google-genai": "^2.1.30",
    "@langchain/openai": "^1.4.5",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/ui": "^4.7.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/oauth-methods": "^6.0.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
