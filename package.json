    "nuxt-auth-utils": "^0.5.29",
    "nuxt-security": "^2.5.1",
    "octokit": "^5.0.5",
    "parse-diff": "^0.11.1",
    "postgres": "^3.4.8",
    "typescript": "^5.9.3",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.3.6"
