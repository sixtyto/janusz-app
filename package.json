    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.22",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.2.3",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/ui": "^4.6.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/oauth-methods": "^6.0.2",
