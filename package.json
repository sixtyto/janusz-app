    "ioredis": "^5.10.0",
    "langchain": "^1.4.0",
    "minimatch": "^10.2.5",
    "nuxt": "^4.4.5",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-security": "^2.6.0",
    "octokit": "^5.0.5",
    "parse-diff": "^0.12.0",
    "postgres": "^3.4.9",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@nuxt/test-utils": "^4.0.3",
